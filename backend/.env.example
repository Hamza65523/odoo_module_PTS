APP_NAME=PTS Backend
ENVIRONMENT=dev
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./pts_backend.db
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
API_KEY=change_me_api_key
CORS_ORIGINS=https://your-odoo-domain.com
ENCRYPTION_KEY=
PTS_BASE_URL=https://192.168.1.117/jsonPTS
PTS_USERNAME=admin
PTS_PASSWORD=admin
# Match PTS DIP switch 2: OFF = digest, ON = basic
PTS_AUTH_MODE=digest
PTS_VERIFY_SSL=false
POLL_INTERVAL_SECONDS=10
