<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pts_status_snapshot_tree" model="ir.ui.view">
        <field name="name">pts.status.snapshot.tree</field>
        <field name="model">pts.status.snapshot</field>
        <field name="arch" type="xml">
            <tree>
                <field name="create_date"/>
                <field name="config_id"/>
                <field name="backend_connected"/>
                <field name="device_connected"/>
            </tree>
        </field>
    </record>

    <record id="action_pts_status_snapshot" model="ir.actions.act_window">
        <field name="name">PTS Status History</field>
        <field name="res_model">pts.status.snapshot</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>
